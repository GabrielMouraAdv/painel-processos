# Prisma
DATABASE_URL="postgresql://user:password@localhost:5432/painel_processos?schema=public"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Supabase Storage (upload de documentos)
# Crie o projeto no Supabase e copie as chaves em Settings -> API.
# Crie um bucket publico chamado "documentos" em Storage (ou deixe o app criar
# automaticamente no primeiro upload usando a service role key abaixo).
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Datajud CNJ (API Publica)
# Chave publica divulgada pelo CNJ em https://datajud-wiki.cnj.jus.br/api-publica/acesso
DATAJUD_API_KEY=""

# Segredo do job automatico de monitoramento.
# Usado em dois lugares:
#  - GET /api/cron/monitoramento  ->  Authorization: Bearer <CRON_SECRET>
#    (chamado pelo Vercel Cron conforme vercel.json)
#  - POST /api/monitoramento/verificar  ->  X-CRON-SECRET: <CRON_SECRET>
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
CRON_SECRET=""
