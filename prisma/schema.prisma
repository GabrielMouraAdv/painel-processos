generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  ADVOGADO
  SECRETARIA
  LEITURA
}

enum TipoProcesso {
  IMPROBIDADE
  ACP
  CRIMINAL
  ACAO_POPULAR
  MANDADO_SEGURANCA
  MANDADO_SEGURANCA_COLETIVO
  HABEAS_CORPUS
  HABEAS_DATA
  ACAO_RESCISORIA
  EXECUCAO_FISCAL
  EXECUCAO_TITULO_EXTRAJUDICIAL
  CUMPRIMENTO_SENTENCA
  ACAO_ORDINARIA
  ACAO_DECLARATORIA
  ACAO_ANULATORIA
  EMBARGOS_EXECUCAO
  EMBARGOS_TERCEIRO
  RECLAMACAO
  CONFLITO_COMPETENCIA
  MEDIDA_CAUTELAR
  TUTELA_CAUTELAR_ANTECEDENTE
  PROCEDIMENTO_COMUM
  JUIZADO_ESPECIAL
  OUTRO
}

enum Tribunal {
  TJPE
  TRF5
  TRF1
  STJ
  STF
  OUTRO
}

enum Grau {
  PRIMEIRO
  SEGUNDO
  SUPERIOR
}

enum Risco {
  ALTO
  MEDIO
  BAIXO
}

enum TipoInteressado {
  PESSOA_FISICA
  PESSOA_JURIDICA
}

model Escritorio {
  id        String   @id @default(cuid())
  nome      String
  cnpj      String   @unique
  createdAt DateTime @default(now())

  usuarios         User[]
  gestores         Gestor[]
  processos        Processo[]
  municipios       Municipio[]
  processosTce     ProcessoTce[]
  sessoesPauta     SessaoPauta[]
  sessoesJudiciais SessaoJudicial[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  nome         String
  senha        String
  role         Role     @default(LEITURA)
  escritorioId String
  createdAt    DateTime @default(now())

  escritorio            Escritorio  @relation(fields: [escritorioId], references: [id], onDelete: Cascade)
  processosComoAdvogado Processo[]  @relation("ProcessoAdvogado")
  prazosComoResp        Prazo[]     @relation("PrazoAdvogadoResp")
  andamentos            Andamento[]
  documentos            Documento[]
  documentosTce         DocumentoTce[]
  andamentosTce         AndamentoTce[] @relation("AutorAndamentoTce")
  prazosTceResp         PrazoTce[]     @relation("AdvogadoRespPrazoTce")

  @@index([escritorioId])
}

model Gestor {
  id              String          @id @default(cuid())
  nome            String
  cpf             String?         @unique
  municipio       String
  cargo           String
  email           String?
  telefone        String?
  observacoes     String?
  tipoInteressado TipoInteressado @default(PESSOA_FISICA)
  razaoSocial     String?
  nomeFantasia    String?
  cnpj            String?
  ramoAtividade   String?
  escritorioId    String
  createdAt       DateTime        @default(now())

  escritorio              Escritorio               @relation(fields: [escritorioId], references: [id], onDelete: Cascade)
  processos               Processo[]
  historicoGestoes        HistoricoGestao[]
  interessadoProcessosTce InteressadoProcessoTce[]
  municipiosAtuacao       GestorMunicipio[]

  @@index([escritorioId])
  @@index([tipoInteressado])
}

model GestorMunicipio {
  id          String   @id @default(cuid())
  gestorId    String
  gestor      Gestor   @relation(fields: [gestorId], references: [id], onDelete: Cascade)
  municipioId String
  municipio   Municipio @relation(fields: [municipioId], references: [id])
  observacao  String?
  createdAt   DateTime @default(now())

  @@unique([gestorId, municipioId])
  @@index([municipioId])
}

model Processo {
  id                   String       @id @default(cuid())
  numero               String       @unique
  tipo                 TipoProcesso
  tribunal             Tribunal
  juizo                String
  grau                 Grau
  fase                 String
  resultado            String?
  risco                Risco
  valor                Decimal?     @db.Decimal(15, 2)
  dataDistribuicao     DateTime
  objeto               String       @db.Text
  memorialPronto             Boolean      @default(false)
  despachadoComRelator       Boolean      @default(false)
  dataDespacho               DateTime?
  retornoDespacho            String?      @db.Text
  memorialAgendadoData       DateTime?
  memorialAgendadoAdvogadoId String?
  despachoAgendadoData       DateTime?
  despachoAgendadoAdvogadoId String?
  memorialDispensado         Boolean      @default(false)
  memorialDispensadoPor      String?
  memorialDispensadoEm       DateTime?
  memorialDispensadoMotivo   String?      @db.Text
  despachoDispensado         Boolean      @default(false)
  despachoDispensadoPor      String?
  despachoDispensadoEm       DateTime?
  despachoDispensadoMotivo   String?      @db.Text
  julgado                    Boolean      @default(false)
  dataJulgamento             DateTime?
  resultadoJulgamento        String?
  penalidade                 String?
  valorCondenacao            Decimal?     @db.Decimal(15, 2)
  observacoesJulgamento      String?      @db.Text
  tipoLivre                  String?
  gestorId                   String
  advogadoId           String
  escritorioId     String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  gestor             Gestor              @relation(fields: [gestorId], references: [id])
  advogado           User                @relation("ProcessoAdvogado", fields: [advogadoId], references: [id])
  escritorio         Escritorio          @relation(fields: [escritorioId], references: [id], onDelete: Cascade)
  andamentos         Andamento[]
  prazos             Prazo[]
  documentos         Documento[]
  itensPautaJudicial ItemPautaJudicial[]
  movimentacoesAuto  MovimentacaoAutomatica[]
  publicacoesDjen    PublicacaoDJEN[]
  monitoramento      MonitoramentoConfig?

  @@index([escritorioId])
  @@index([gestorId])
  @@index([advogadoId])
  @@index([tipo])
  @@index([risco])
}

model Andamento {
  id         String   @id @default(cuid())
  processoId String
  data       DateTime
  grau       Grau
  fase       String
  resultado  String?
  texto      String   @db.Text
  autorId    String
  createdAt  DateTime @default(now())

  processo Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)
  autor    User     @relation(fields: [autorId], references: [id])

  @@index([processoId])
  @@index([autorId])
}

model Prazo {
  id               String   @id @default(cuid())
  processoId       String
  tipo             String
  data             DateTime
  hora             String?
  observacoes      String?
  cumprido         Boolean  @default(false)
  geradoAuto       Boolean  @default(false)
  origemFase       String?
  advogadoRespId   String?
  dispensado       Boolean  @default(false)
  dispensadoPor    String?
  dispensadoEm     DateTime?
  dispensadoMotivo String?  @db.Text
  createdAt        DateTime @default(now())

  processo     Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)
  advogadoResp User?    @relation("PrazoAdvogadoResp", fields: [advogadoRespId], references: [id])

  @@index([processoId])
  @@index([data])
  @@index([cumprido])
  @@index([advogadoRespId])
}

model Documento {
  id         String   @id @default(cuid())
  processoId String
  nome       String
  url        String
  tipo       String
  tamanho    Int
  uploadedBy String
  createdAt  DateTime @default(now())

  processo       Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)
  uploadedByUser User     @relation(fields: [uploadedBy], references: [id])

  @@index([processoId])
  @@index([uploadedBy])
}

model DocumentoTce {
  id             String   @id @default(cuid())
  processoTceId  String
  nome           String
  url            String
  tipo           String
  tamanho        Int
  uploadedBy     String
  createdAt      DateTime @default(now())

  processo       ProcessoTce @relation(fields: [processoTceId], references: [id], onDelete: Cascade)
  uploadedByUser User        @relation(fields: [uploadedBy], references: [id])

  @@index([processoTceId])
  @@index([uploadedBy])
}

enum TipoProcessoTce {
  PRESTACAO_CONTAS_GOVERNO
  PRESTACAO_CONTAS_GESTAO
  AUDITORIA_ESPECIAL
  RGF
  AUTO_INFRACAO
  MEDIDA_CAUTELAR
  TOMADA_CONTAS_ESPECIAL
  DESTAQUE
  DENUNCIA
  TERMO_AJUSTE_GESTAO
  PEDIDO_RESCISAO
  CONSULTA
}

enum CamaraTce {
  PRIMEIRA
  SEGUNDA
  PLENO
}

model Municipio {
  id             String   @id @default(cuid())
  nome           String
  uf             String
  cnpjPrefeitura String?
  observacoes    String?
  escritorioId   String
  createdAt      DateTime @default(now())

  escritorio         Escritorio        @relation(fields: [escritorioId], references: [id])
  processosTce       ProcessoTce[]     @relation("MunicipioProcessos")
  gestoes            HistoricoGestao[]
  gestoresVinculados GestorMunicipio[]

  @@index([escritorioId])
}

model HistoricoGestao {
  id          String    @id @default(cuid())
  municipioId String
  gestorId    String
  cargo       String
  dataInicio  DateTime
  dataFim     DateTime?
  createdAt   DateTime  @default(now())

  municipio Municipio @relation(fields: [municipioId], references: [id], onDelete: Cascade)
  gestor    Gestor    @relation(fields: [gestorId], references: [id])

  @@index([municipioId])
  @@index([gestorId])
}

model ProcessoTce {
  id                    String          @id @default(cuid())
  numero                String
  tipo                  TipoProcessoTce
  municipioId           String?
  relator               String?
  camara                CamaraTce
  faseAtual             String
  conselheiroSubstituto String?
  notaTecnica                   Boolean   @default(false)
  parecerMpco                   Boolean   @default(false)
  despachadoComRelator          Boolean   @default(false)
  memorialPronto                Boolean   @default(false)
  memorialAgendadoData          DateTime?
  memorialAgendadoAdvogadoId    String?
  contrarrazoesNtApresentadas   Boolean   @default(false)
  contrarrazoesMpcoApresentadas Boolean   @default(false)
  contrarrazoesNtDispensadas      Boolean   @default(false)
  contrarrazoesNtDispensadoPor    String?
  contrarrazoesNtDispensadoEm     DateTime?
  contrarrazoesNtDispensadoMotivo String?   @db.Text
  contrarrazoesMpcoDispensadas      Boolean   @default(false)
  contrarrazoesMpcoDispensadoPor    String?
  contrarrazoesMpcoDispensadoEm     DateTime?
  contrarrazoesMpcoDispensadoMotivo String?   @db.Text
  julgado                       Boolean   @default(false)
  dataJulgamento                DateTime?
  resultadoJulgamento           String?
  penalidade                    String?
  valorMulta                    Decimal?  @db.Decimal(15, 2)
  valorDevolucao                Decimal?  @db.Decimal(15, 2)
  observacoesJulgamento         String?   @db.Text
  prognosticoDespacho           String?   @db.Text
  retornoDespacho               String?   @db.Text
  dataDespacho                  DateTime?
  incluidoNoDespacho            Boolean   @default(false)
  despachoAgendadoData          DateTime?
  despachoAgendadoAdvogadoId    String?
  memorialDispensado            Boolean   @default(false)
  memorialDispensadoPor         String?
  memorialDispensadoEm          DateTime?
  memorialDispensadoMotivo      String?   @db.Text
  despachoDispensado            Boolean   @default(false)
  despachoDispensadoPor         String?
  despachoDispensadoEm          DateTime?
  despachoDispensadoMotivo      String?   @db.Text
  exercicio             String?
  valorAutuado          Decimal?        @db.Decimal(15, 2)
  objeto                String          @db.Text
  dataAutuacao          DateTime?
  dataIntimacao         DateTime?
  bancasSlug            String[]        @default([])
  escritorioId          String
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  municipio    Municipio?               @relation("MunicipioProcessos", fields: [municipioId], references: [id])
  escritorio   Escritorio               @relation(fields: [escritorioId], references: [id])
  interessados InteressadoProcessoTce[]
  andamentos   AndamentoTce[]
  prazos       PrazoTce[]
  itensPauta   ItemPauta[]
  documentos   DocumentoTce[]
  subprocessos SubprocessoTce[]

  @@index([escritorioId])
  @@index([municipioId])
  @@index([tipo])
  @@index([camara])
}

model InteressadoProcessoTce {
  id         String   @id @default(cuid())
  processoId String
  gestorId   String
  cargo      String
  createdAt  DateTime @default(now())

  processo ProcessoTce @relation(fields: [processoId], references: [id], onDelete: Cascade)
  gestor   Gestor      @relation(fields: [gestorId], references: [id])

  @@index([processoId])
  @@index([gestorId])
}

model AndamentoTce {
  id         String   @id @default(cuid())
  processoId String
  data       DateTime
  fase       String
  descricao  String   @db.Text
  autorId    String
  createdAt  DateTime @default(now())

  processo ProcessoTce @relation(fields: [processoId], references: [id], onDelete: Cascade)
  autor    User        @relation("AutorAndamentoTce", fields: [autorId], references: [id])

  @@index([processoId])
  @@index([autorId])
}

model PrazoTce {
  id                String    @id @default(cuid())
  processoId        String
  tipo              String
  dataIntimacao     DateTime
  dataVencimento    DateTime
  diasUteis         Int
  prorrogavel       Boolean   @default(true)
  prorrogacaoPedida Boolean   @default(false)
  dataProrrogacao   DateTime?
  cumprido          Boolean   @default(false)
  advogadoRespId    String?
  observacoes       String?
  dispensado        Boolean   @default(false)
  dispensadoPor     String?
  dispensadoEm      DateTime?
  dispensadoMotivo  String?   @db.Text
  createdAt         DateTime  @default(now())

  processo     ProcessoTce @relation(fields: [processoId], references: [id], onDelete: Cascade)
  advogadoResp User?       @relation("AdvogadoRespPrazoTce", fields: [advogadoRespId], references: [id])

  @@index([processoId])
  @@index([dataVencimento])
  @@index([cumprido])
  @@index([advogadoRespId])
}

model SessaoPauta {
  id                String    @id @default(cuid())
  data              DateTime
  camara            CamaraTce
  observacoesGerais String?   @db.Text
  escritorioId      String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  escritorio Escritorio  @relation(fields: [escritorioId], references: [id], onDelete: Cascade)
  itens      ItemPauta[]

  @@index([escritorioId, data])
}

model ItemPauta {
  id                String   @id @default(cuid())
  sessaoId          String
  numeroProcesso    String
  tituloProcesso    String?
  municipio         String
  exercicio         String?
  relator           String
  advogadoResp      String
  situacao          String?  @db.Text
  observacoes       String?  @db.Text
  prognostico       String?
  providencia       String?
  retiradoDePauta   Boolean  @default(false)
  pedidoVistas      Boolean  @default(false)
  conselheiroVistas String?
  processoTceId     String?
  ordem             Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  sessao      SessaoPauta  @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  processoTce ProcessoTce? @relation(fields: [processoTceId], references: [id])

  @@index([sessaoId])
  @@index([processoTceId])
}

model SessaoJudicial {
  id                String   @id @default(cuid())
  data              DateTime
  tribunal          String
  orgaoJulgador     String
  tipoSessao        String   @default("presencial")
  observacoesGerais String?  @db.Text
  escritorioId      String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  escritorio Escritorio          @relation(fields: [escritorioId], references: [id], onDelete: Cascade)
  itens      ItemPautaJudicial[]

  @@index([escritorioId, data])
}

model ItemPautaJudicial {
  id                  String   @id @default(cuid())
  sessaoId            String
  numeroProcesso      String
  tituloProcesso      String?
  tipoRecurso         String?
  partes              String?  @db.Text
  relator             String
  advogadoResp        String
  situacao            String?  @db.Text
  prognostico         String?
  observacoes         String?  @db.Text
  providencia         String?
  sustentacaoOral     Boolean  @default(false)
  advogadoSustentacao String?
  sessaoVirtual       Boolean  @default(false)
  pedidoRetPresencial Boolean  @default(false)
  retiradoDePauta     Boolean  @default(false)
  pedidoVistas        Boolean  @default(false)
  desPedidoVistas     String?
  parecerMpf          Boolean  @default(false)
  processoId          String?
  ordem               Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  sessao   SessaoJudicial @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  processo Processo?      @relation(fields: [processoId], references: [id])

  @@index([sessaoId])
  @@index([processoId])
}

model MovimentacaoAutomatica {
  id              String    @id @default(cuid())
  processoId      String
  processo        Processo  @relation(fields: [processoId], references: [id], onDelete: Cascade)
  codigoMovimento String?
  nomeMovimento   String
  descricao       String?   @db.Text
  dataMovimento   DateTime
  complementos    String?   @db.Text
  fonte           String    @default("DATAJUD")
  lida            Boolean   @default(false)
  createdAt       DateTime  @default(now())

  @@unique([processoId, dataMovimento, nomeMovimento])
  @@index([processoId, lida])
}

model PublicacaoDJEN {
  id                   String    @id @default(cuid())
  processoId           String
  processo             Processo  @relation(fields: [processoId], references: [id], onDelete: Cascade)
  dataPublicacao       DateTime
  dataDisponibilizacao DateTime?
  conteudo             String?   @db.Text
  caderno              String?
  pagina               String?
  fonte                String    @default("DJEN")
  lida                 Boolean   @default(false)
  geraIntimacao        Boolean   @default(false)
  createdAt            DateTime  @default(now())

  @@unique([processoId, dataPublicacao, conteudo])
  @@index([processoId, lida])
}

model MonitoramentoConfig {
  id                 String    @id @default(cuid())
  processoId         String    @unique
  processo           Processo  @relation(fields: [processoId], references: [id], onDelete: Cascade)
  monitoramentoAtivo Boolean   @default(true)
  ultimaVerificacao  DateTime?
  ultimoErro         String?
  totalVerificacoes  Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

enum TipoRecursoTce {
  RECURSO_ORDINARIO
  EMBARGOS_DECLARACAO
  AGRAVO
  AGRAVO_REGIMENTAL
  PEDIDO_RESCISAO_RECURSO
  PEDIDO_SUSPENSAO_CAUTELAR
}

model SubprocessoTce {
  id                String         @id @default(cuid())
  processoPaiId     String
  processoPai       ProcessoTce    @relation(fields: [processoPaiId], references: [id], onDelete: Cascade)
  subprocessoPaiId  String?
  subprocessoPai    SubprocessoTce? @relation("SubprocessoPaiFilho", fields: [subprocessoPaiId], references: [id], onDelete: Cascade)
  subprocessosFilhos SubprocessoTce[] @relation("SubprocessoPaiFilho")
  numero            String
  tipoRecurso       TipoRecursoTce
  numeroSequencial  Int
  dataInterposicao  DateTime
  dataIntimacao     DateTime?
  fase                 String
  relator              String?
  decisao              String?        @db.Text
  observacoes          String?        @db.Text
  memorialPronto             Boolean        @default(false)
  despachadoComRelator       Boolean        @default(false)
  prognosticoDespacho        String?        @db.Text
  retornoDespacho            String?        @db.Text
  dataDespacho               DateTime?
  memorialAgendadoData       DateTime?
  memorialAgendadoAdvogadoId String?
  despachoAgendadoData       DateTime?
  despachoAgendadoAdvogadoId String?
  memorialDispensado         Boolean        @default(false)
  memorialDispensadoPor      String?
  memorialDispensadoEm       DateTime?
  memorialDispensadoMotivo   String?        @db.Text
  despachoDispensado         Boolean        @default(false)
  despachoDispensadoPor      String?
  despachoDispensadoEm       DateTime?
  despachoDispensadoMotivo   String?        @db.Text
  bancasSlug                 String[]       @default([])
  prazos                     PrazoSubprocessoTce[]
  andamentos           AndamentoSubprocessoTce[]
  documentos           DocumentoSubprocessoTce[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([processoPaiId])
  @@index([subprocessoPaiId])
}

model PrazoSubprocessoTce {
  id                String         @id @default(cuid())
  subprocessoId     String
  subprocesso       SubprocessoTce @relation(fields: [subprocessoId], references: [id], onDelete: Cascade)
  tipo              String
  dataIntimacao     DateTime
  dataVencimento    DateTime
  diasUteis         Int
  prorrogavel       Boolean        @default(true)
  prorrogacaoPedida Boolean        @default(false)
  cumprido          Boolean        @default(false)
  advogadoRespId    String?
  observacoes       String?
  dispensado        Boolean        @default(false)
  dispensadoPor     String?
  dispensadoEm      DateTime?
  dispensadoMotivo  String?        @db.Text
  createdAt         DateTime       @default(now())

  @@index([subprocessoId])
  @@index([dataVencimento])
  @@index([cumprido])
}

model AndamentoSubprocessoTce {
  id            String         @id @default(cuid())
  subprocessoId String
  subprocesso   SubprocessoTce @relation(fields: [subprocessoId], references: [id], onDelete: Cascade)
  data          DateTime
  fase          String
  descricao     String         @db.Text
  autorId       String
  createdAt     DateTime       @default(now())

  @@index([subprocessoId])
}

model DocumentoSubprocessoTce {
  id            String         @id @default(cuid())
  subprocessoId String
  subprocesso   SubprocessoTce @relation(fields: [subprocessoId], references: [id], onDelete: Cascade)
  nome          String
  url           String
  tipo          String
  tamanho       Int
  uploadedBy    String
  createdAt     DateTime       @default(now())

  @@index([subprocessoId])
}
