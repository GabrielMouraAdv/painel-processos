generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  ADVOGADO
  SECRETARIA
  LEITURA
}

enum TipoProcesso {
  IMPROBIDADE
  ACP
  CRIMINAL
}

enum Tribunal {
  TJPE
  TRF5
  TRF1
  STJ
  STF
  OUTRO
}

enum Grau {
  PRIMEIRO
  SEGUNDO
  SUPERIOR
}

enum Risco {
  ALTO
  MEDIO
  BAIXO
}

model Escritorio {
  id        String   @id @default(cuid())
  nome      String
  cnpj      String   @unique
  createdAt DateTime @default(now())

  usuarios  User[]
  gestores  Gestor[]
  processos Processo[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  nome         String
  senha        String
  role         Role     @default(LEITURA)
  escritorioId String
  createdAt    DateTime @default(now())

  escritorio            Escritorio  @relation(fields: [escritorioId], references: [id], onDelete: Cascade)
  processosComoAdvogado Processo[]  @relation("ProcessoAdvogado")
  andamentos            Andamento[]
  documentos            Documento[]

  @@index([escritorioId])
}

model Gestor {
  id           String   @id @default(cuid())
  nome         String
  cpf          String   @unique
  municipio    String
  cargo        String
  observacoes  String?
  escritorioId String
  createdAt    DateTime @default(now())

  escritorio Escritorio @relation(fields: [escritorioId], references: [id], onDelete: Cascade)
  processos  Processo[]

  @@index([escritorioId])
}

model Processo {
  id               String       @id @default(cuid())
  numero           String       @unique
  tipo             TipoProcesso
  tribunal         Tribunal
  juizo            String
  grau             Grau
  fase             String
  resultado        String?
  risco            Risco
  valor            Decimal?     @db.Decimal(15, 2)
  dataDistribuicao DateTime
  objeto           String       @db.Text
  gestorId         String
  advogadoId       String
  escritorioId     String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  gestor     Gestor      @relation(fields: [gestorId], references: [id])
  advogado   User        @relation("ProcessoAdvogado", fields: [advogadoId], references: [id])
  escritorio Escritorio  @relation(fields: [escritorioId], references: [id], onDelete: Cascade)
  andamentos Andamento[]
  prazos     Prazo[]
  documentos Documento[]

  @@index([escritorioId])
  @@index([gestorId])
  @@index([advogadoId])
  @@index([tipo])
  @@index([risco])
}

model Andamento {
  id         String   @id @default(cuid())
  processoId String
  data       DateTime
  grau       Grau
  fase       String
  resultado  String?
  texto      String   @db.Text
  autorId    String
  createdAt  DateTime @default(now())

  processo Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)
  autor    User     @relation(fields: [autorId], references: [id])

  @@index([processoId])
  @@index([autorId])
}

model Prazo {
  id          String   @id @default(cuid())
  processoId  String
  tipo        String
  data        DateTime
  hora        String?
  observacoes String?
  cumprido    Boolean  @default(false)
  geradoAuto  Boolean  @default(false)
  origemFase  String?
  createdAt   DateTime @default(now())

  processo Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)

  @@index([processoId])
  @@index([data])
  @@index([cumprido])
}

model Documento {
  id         String   @id @default(cuid())
  processoId String
  nome       String
  url        String
  tipo       String
  tamanho    Int
  uploadedBy String
  createdAt  DateTime @default(now())

  processo       Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)
  uploadedByUser User     @relation(fields: [uploadedBy], references: [id])

  @@index([processoId])
  @@index([uploadedBy])
}
